step_github() {
  local target="$1"
  local org_name="${2:-}"
  local token="${3:-${GITHUB_TOKEN:-}}"
  local subs_out="${4:-github_subs.txt}"
  local secrets_out="${5:-github_secrets.json}"
  local cfor_out="${secrets_out%.json}_cfor.json"
  local workflows_out="${secrets_out%.json}_workflows.txt"

  if [[ -z "$target" ]]; then
    echo "Uso: recon github <dominio> [--org org_name] [--token GITHUB_TOKEN] [--subs-out github_subs.txt] [--secrets-out github_secrets.json]" >&2
    return 1
  fi

  if [[ -z "$org_name" ]]; then
    org_name=$(echo "$target" | awk -F. '{print $1}')
  fi

  : > "$subs_out"
  : > "$secrets_out"

  if [[ -z "$token" ]]; then
    echo "[!] GITHUB_TOKEN nao informado; pulando github-subdomains e trufflehog." >&2
    return 0
  fi

  echo "[6/6] GitHub recon para dominio: $target | org: $org_name"

  # github-subdomains: subdominios vazados em codigo publico.
  if command -v github-subdomains >/dev/null 2>&1; then
    github-subdomains -d "$target" -t "$token" -o "$subs_out" >/dev/null 2>&1 || true
  else
    echo "[!] github-subdomains ausente." >> "$subs_out"
  fi

  # trufflehog: secrets em repos da organizacao.
  if command -v trufflehog >/dev/null 2>&1; then
    trufflehog github --org="$org_name" --token="$token" --only-verified --json > "$secrets_out" 2>/dev/null || true
  else
    echo "{\"warning\":\"trufflehog ausente\"}" > "$secrets_out"
  fi

  # BLOCO 1 — CFOR (Cross-Fork Object Reference)
  : > "$cfor_out"
  if command -v trufflehog >/dev/null 2>&1 && [[ -n "$token" ]]; then
    trufflehog github --org="$org_name" --token="$token" --object-discovery --only-verified --json > "$cfor_out" 2>/dev/null || true
  fi

  if command -v gitleaks >/dev/null 2>&1; then
    gitleaks detect --source . --report-path "${secrets_out%.json}_gitleaks.json" -q 2>/dev/null || true
  fi

  local cfor_total
  cfor_total=$(wc -l < "$cfor_out" 2>/dev/null || echo 0)
  echo "[6/6] CFOR finalizado: $cfor_out (${cfor_total} findings)"

  # BLOCO 2 — CI/CD Workflow scanning
  : > "$workflows_out"
  if [[ -n "$token" ]]; then
    curl -s -H "Authorization: Bearer ${token}" \
      "https://api.github.com/orgs/${org_name}/repos?per_page=100" 2>/dev/null | \
      jq -r '.[].full_name?' 2>/dev/null | while read -r repo; do
        [[ -z "$repo" ]] && continue
        curl -s -H "Authorization: Bearer ${token}" \
          "https://api.github.com/repos/${repo}/contents/.github/workflows" 2>/dev/null | \
          jq -r '.[].download_url?' 2>/dev/null | while read -r wf_url; do
            [[ -z "$wf_url" ]] && continue
            curl -s "$wf_url" 2>/dev/null | grep -E '(SECRET|TOKEN|PASSWORD|KEY|CREDENTIAL)\s*[:=]' >> "$workflows_out" || true
          done
      done
  fi

  local workflows_total
  workflows_total=$(wc -l < "$workflows_out" 2>/dev/null || echo 0)
  echo "[6/6] Workflow scan finalizado: $workflows_out (${workflows_total} linhas suspeitas)"

  # Mescla subdominios do github-subdomains no inventario.
  if [[ -f "$subs_out" ]]; then
    cat "$subs_out" \
      | tr '[:upper:]' '[:lower:]' \
      | grep -E "([a-zA-Z0-9._-]+\.)+${target//./\\.}$" \
      | sed 's/^\*\.//' \
      | anew_or_append all_subs.txt || true
  fi

  local total_subs total_secrets
  total_subs=$(wc -l < "$subs_out" 2>/dev/null || echo 0)
  total_secrets=$(wc -l < "$secrets_out" 2>/dev/null || echo 0)
  echo "[6/6] GitHub recon finalizado: $subs_out (${total_subs} linhas), $secrets_out (${total_secrets} linhas)"
}

step_crawl_js() {
  local live_file="${1:-live.txt}"
  local katana_out="${2:-katana_urls.txt}"
  local gau_out="${3:-gau_urls.txt}"
  local all_out="${4:-all_urls.txt}"
  local sensitive_out="${5:-sensitive_files.txt}"

  if [[ ! -f "$live_file" ]]; then
    echo "[!] Arquivo de alvos vivos nao encontrado: $live_file" >&2
    return 1
  fi

  require_cmd sort
  require_cmd grep

  local targets_file
  targets_file=$(mktemp)
  awk '{print $1}' "$live_file" | grep -E '^https?://' | sort -u > "$targets_file" || true

  if [[ ! -s "$targets_file" ]]; then
    echo "[!] Nenhum alvo HTTP valido encontrado em $live_file" >&2
    rm -f "$targets_file"
    return 1
  fi

  : > "$katana_out"
  : > "$gau_out"

  echo "[6/6] Crawling ativo (katana + gospider)..."
  if command -v katana >/dev/null 2>&1; then
    katana -list "$targets_file" -d 5 -jc -silent -o "$katana_out" >/dev/null 2>&1 || true
  fi

  if command -v gospider >/dev/null 2>&1; then
    gospider -S "$targets_file" -d 3 -c 10 --js -q 2>/dev/null | \
      grep -oE 'https?://[^"]+' >> "$katana_out" || true
  fi
  sort -u "$katana_out" -o "$katana_out" || true

  echo "[6/6] URLs historicas (gau + waybackurls)..."
  if command -v gau >/dev/null 2>&1; then
    cat "$targets_file" | gau --threads 5 2>/dev/null | sort -u > "$gau_out" || true
  fi
  if command -v waybackurls >/dev/null 2>&1; then
    cat "$targets_file" | waybackurls 2>/dev/null | sort -u >> "$gau_out" || true
  fi
  if command -v waymore >/dev/null 2>&1; then
    cat "$targets_file" | sed 's#https\?://##' | while read -r t; do
      waymore -i "$t" -mode U -oU /dev/stdout 2>/dev/null >> "$gau_out" || true
    done
  fi
  sort -u "$gau_out" -o "$gau_out" || true

  cat "$gau_out" "$katana_out" 2>/dev/null > "${all_out}.tmp" || true
  if command -v uro >/dev/null 2>&1; then
    cat "${all_out}.tmp" | uro 2>/dev/null | sort -u > "$all_out" || true
  else
    sort -u "${all_out}.tmp" > "$all_out" || true
  fi
  if command -v anew >/dev/null 2>&1; then
    sort -u "$all_out" -o "$all_out" 2>/dev/null || true
  fi

  echo "[6/6] Filtrando arquivos sensiveis das URLs..."
  grep -iE '\.(xls|xlsx|xml|json|pdf|sql|doc|docx|zip|bak|config|conf|yaml|yml|env|log|backup|swp|DS_Store|git|svn)([?#].*)?$' \
    "$all_out" 2>/dev/null | sort -u > "$sensitive_out" || true

  if [[ -s "$sensitive_out" ]]; then
    echo "[6/6] Verificando quais arquivos sensiveis ainda respondem..."
    local sensitive_live_out="${sensitive_out%.txt}_live.txt"
    cat "$sensitive_out" | httpx -silent -mc 200 -o "$sensitive_live_out" 2>/dev/null || true
    local s_live
    s_live=$(wc -l < "$sensitive_live_out" 2>/dev/null || echo 0)
    echo "[6/6] Arquivos sensiveis vivos: $sensitive_live_out (${s_live})"
  fi

  local s_total
  s_total=$(wc -l < "$sensitive_out" 2>/dev/null || echo 0)
  echo "[6/6] Arquivos sensiveis encontrados: $sensitive_out (${s_total})"

  rm -f "${all_out}.tmp" "$targets_file"

  local t1 t2 t3
  t1=$(wc -l < "$katana_out" 2>/dev/null || echo 0)
  t2=$(wc -l < "$gau_out" 2>/dev/null || echo 0)
  t3=$(wc -l < "$all_out" 2>/dev/null || echo 0)
  echo "[6/6] Crawl/JS finalizado: $katana_out (${t1}), $gau_out (${t2}), $all_out (${t3})"
}

step_params() {
  local urls_file="${1:-all_urls.txt}"
  local output="${2:-params_found.json}"
  local threads="${3:-10}"
  local max_targets="${4:-50}"

  if ! command -v arjun >/dev/null 2>&1; then
    echo "[!] arjun nao encontrado. Pulando parameter discovery."
    return 0
  fi

  if [[ ! -f "$urls_file" ]] || [[ ! -s "$urls_file" ]]; then
    echo "[!] Arquivo de URLs nao encontrado: $urls_file" >&2
    return 1
  fi

  grep -E '^https?://' "$urls_file" \
    | grep -vE '\.(js|css|png|jpg|jpeg|gif|ico|woff|woff2|svg|map|ttf|eot)([?#].*)?$' \
    | sort -u \
    | head -"$max_targets" > /tmp/arjun_targets.txt || true

  if [[ ! -s /tmp/arjun_targets.txt ]]; then
    echo "[6/6] Nenhum endpoint candidato para arjun."
    rm -f /tmp/arjun_targets.txt
    return 0
  fi

  : > "$output"
  arjun -i /tmp/arjun_targets.txt \
    -m GET,POST \
    -t "$threads" \
    --passive \
    -oT "$output" \
    -q 2>/dev/null || true

  local total
  total=$(jq -r 'if type=="array" then length else 0 end' "$output" 2>/dev/null || echo 0)
  if [[ "$total" == "0" ]]; then
    total=$(wc -l < "$output" 2>/dev/null || echo 0)
  fi
  echo "[6/6] Parameter discovery finalizado: $output (${total} entradas)"

  rm -f /tmp/arjun_targets.txt
}

step_js_secrets() {
  local urls_file="${1:-all_urls.txt}"
  local js_files_out="${2:-js_files.txt}"
  local exposures_out="${3:-js_exposures.txt}"
  local secrets_out="${4:-secrets.txt}"
  local templates_dir="${5:-~/nuclei-templates/exposures/}"
  local secretfinder_path="${6:-SecretFinder.py}"
  local jsluice_out="${js_files_out%.txt}_jsluice_urls.txt"

  if [[ ! -f "$urls_file" ]]; then
    echo "[!] Arquivo de URLs nao encontrado: $urls_file" >&2
    return 1
  fi

  require_cmd grep
  require_cmd httpx

  : > "$js_files_out"
  : > "$exposures_out"
  : > "$secrets_out"

  echo "[6/6] Extraindo JS vivos..."
  cat "$urls_file" | grep -E '\\.js([?#].*)?$' | httpx -silent > "$js_files_out" || true

  if command -v getJS >/dev/null 2>&1 && [[ -f "resolved.txt" ]]; then
    echo "[6/6] Descobrindo JS via getJS..."
    local getjs_out
    getjs_out=$(mktemp)
    cat resolved.txt | getJS --complete 2>/dev/null > "$getjs_out" || true
    if [[ -s "$getjs_out" ]]; then
      cat "$getjs_out" | httpx -silent -mc 200 2>/dev/null | anew_or_append "$js_files_out" || true
    fi
    rm -f "$getjs_out"
  fi

  if [[ ! -s "$js_files_out" ]]; then
    echo "[6/6] Nenhum JS vivo encontrado em $urls_file"
    return 0
  fi

  if command -v jsluice >/dev/null 2>&1; then
    xargs -I{} -a "$js_files_out" jsluice urls {} 2>/dev/null | jq -r '.url' 2>/dev/null | sort -u > "$jsluice_out" || true
    xargs -I{} -a "$js_files_out" jsluice secrets {} 2>/dev/null | jq -r '.value' 2>/dev/null | sort -u >> "$secrets_out" || true
    cat "$jsluice_out" 2>/dev/null | anew_or_append all_urls.txt || true

    local jsluice_urls_total jsluice_secrets_total
    jsluice_urls_total=$(wc -l < "$jsluice_out" 2>/dev/null || echo 0)
    jsluice_secrets_total=$(wc -l < "$secrets_out" 2>/dev/null || echo 0)
    echo "[6/6] jsluice finalizado: $jsluice_out (${jsluice_urls_total} urls), $secrets_out (${jsluice_secrets_total} secrets acumulados)"
  fi

  echo "[6/6] Rodando nuclei (templates exposures)..."
  if command -v nuclei >/dev/null 2>&1; then
    # shellcheck disable=SC2086
    nuclei -l "$js_files_out" -t ${templates_dir} -o "$exposures_out" >/dev/null 2>&1 || true
  else
    echo "[!] nuclei ausente." >> "$exposures_out"
  fi

  echo "[6/6] Rodando SecretFinder..."
  if command -v python3 >/dev/null 2>&1 && [[ -f "$secretfinder_path" ]]; then
    python3 "$secretfinder_path" -i "$js_files_out" -o "$secrets_out" >/dev/null 2>&1 || true
  else
    echo "[!] SecretFinder.py nao encontrado ou python3 ausente." > "$secrets_out"
  fi

  local js_endpoints_out="${js_files_out%.txt}_endpoints.txt"
  echo "[6/6] Extraindo endpoints inline dos arquivos JS..."
  if [[ -s "$js_files_out" ]]; then
    while IFS= read -r js_url; do
      curl -sk "$js_url" 2>/dev/null \
        | grep -aoP "(?<=[\"'\`])/[a-zA-Z0-9_?&=\\/-#\\.]{3,100}(?=[\"'\`])" \
        | grep -v "^//" \
        2>/dev/null >> "$js_endpoints_out" || true
    done < "$js_files_out"
    sort -u "$js_endpoints_out" -o "$js_endpoints_out" 2>/dev/null || true

    if [[ -f "paths.txt" ]] && [[ -s "$js_endpoints_out" ]]; then
      cat "$js_endpoints_out" | sed 's#^/##' | anew_or_append paths.txt || true
      echo "[6/6] Endpoints JS adicionados ao paths.txt"
    fi
  fi
  local ep_total
  ep_total=$(wc -l < "$js_endpoints_out" 2>/dev/null || echo 0)
  echo "[6/6] Endpoints JS extraidos: $js_endpoints_out (${ep_total})"

  local t1 t2 t3
  t1=$(wc -l < "$js_files_out" 2>/dev/null || echo 0)
  t2=$(wc -l < "$exposures_out" 2>/dev/null || echo 0)
  t3=$(wc -l < "$secrets_out" 2>/dev/null || echo 0)
  echo "[6/6] JS secrets finalizado: $js_files_out (${t1}), $exposures_out (${t2}), $secrets_out (${t3})"
}

step_takeover() {
  local input="${1:-all_subs_merged.txt}"
  local nuclei_out="${2:-takeover_findings.txt}"
  local subzy_out="${3:-subzy_results.txt}"
  local templates_dir="${4:-~/nuclei-templates/takeovers/}"
  local nuclei_vuln_out="${nuclei_out%.txt}_vulns.txt"
  local nuclei_tech_out="${nuclei_out%.txt}_tech.txt"

  if [[ ! -f "$input" ]]; then
    echo "[!] Arquivo de subdominios nao encontrado: $input" >&2
    return 1
  fi

  : > "$nuclei_out"
  : > "$subzy_out"

  echo "[6/6] Detectando takeover (nuclei + subzy)..."

  if command -v nuclei >/dev/null 2>&1; then
    # shellcheck disable=SC2086
    nuclei -l "$input" -t ${templates_dir} -o "$nuclei_out" -silent >/dev/null 2>&1 || true

    nuclei -l "$input" \
      -t ~/nuclei-templates/cves/ \
      -t ~/nuclei-templates/exposures/ \
      -t ~/nuclei-templates/misconfiguration/ \
      -severity critical,high,medium \
      -rate-limit 50 \
      -bulk-size 25 \
      -silent \
      -o "$nuclei_vuln_out" 2>/dev/null || true

    nuclei -l "$input" \
      -t ~/nuclei-templates/technologies/ \
      -rate-limit 100 \
      -silent \
      -o "$nuclei_tech_out" 2>/dev/null || true
  else
    echo "[!] nuclei ausente." >> "$nuclei_out"
  fi

  if command -v subzy >/dev/null 2>&1; then
    subzy run --targets "$input" --output "$subzy_out" >/dev/null 2>&1 || true
  else
    echo "[!] subzy ausente." >> "$subzy_out"
  fi

  local t1 t2 t3 t4
  t1=$(wc -l < "$nuclei_out" 2>/dev/null || echo 0)
  t2=$(wc -l < "$subzy_out" 2>/dev/null || echo 0)
  t3=$(wc -l < "$nuclei_vuln_out" 2>/dev/null || echo 0)
  t4=$(wc -l < "$nuclei_tech_out" 2>/dev/null || echo 0)
  echo "[6/6] Takeover finalizado: $nuclei_out (${t1}), $subzy_out (${t2}), $nuclei_vuln_out (${t3}), $nuclei_tech_out (${t4})"
}

step_cloud() {
  local target="$1"
  local keyword="${2:-}"
  local cloud_out="${3:-cloud_findings.txt}"
  local s3_out="${4:-s3_findings.txt}"
  local threads="${5:-10}"
  local disable_azure="${6:-1}"

  if [[ -z "$target" ]]; then
    echo "Uso: recon cloud <dominio> [--keyword keyword] [--cloud-out cloud_findings.txt] [--s3-out s3_findings.txt] [--threads 10] [--disable-azure]" >&2
    return 1
  fi

  if [[ -z "$keyword" ]]; then
    keyword=$(echo "$target" | awk -F. '{print $1}')
  fi

  : > "$cloud_out"
  : > "$s3_out"

  echo "[6/6] Cloud discovery com keyword: $keyword"

  # cloud_enum (AWS/GCP/Azure; com opcao para desabilitar Azure).
  if command -v python3 >/dev/null 2>&1; then
    if [[ -f "cloud_enum.py" ]]; then
      if [[ "$disable_azure" == "1" ]]; then
        python3 cloud_enum.py -k "$keyword" --disable-azure --threads "$threads" -l "$cloud_out" >/dev/null 2>&1 || true
      else
        python3 cloud_enum.py -k "$keyword" --threads "$threads" -l "$cloud_out" >/dev/null 2>&1 || true
      fi
    else
      echo "[!] cloud_enum.py nao encontrado no diretorio atual." >> "$cloud_out"
    fi
  else
    echo "[!] python3 ausente; cloud_enum nao executado." >> "$cloud_out"
  fi

  # S3Scanner via root_domains.txt (fallback para target quando arquivo nao existir).
  if command -v s3scanner >/dev/null 2>&1; then
    local domains_file
    domains_file=$(mktemp)
    if [[ -f "root_domains.txt" ]] && [[ -s "root_domains.txt" ]]; then
      cp "root_domains.txt" "$domains_file"
    else
      echo "$target" > "$domains_file"
    fi
    s3scanner scan --domains-file "$domains_file" > "$s3_out" 2>/dev/null || true
    rm -f "$domains_file"
  else
    echo "[!] s3scanner ausente; varredura S3 nao executada." >> "$s3_out"
  fi

  # Extrai potenciais hosts de storage para enriquecer all_subs quando aplicavel.
  cat "$cloud_out" "$s3_out" 2>/dev/null \
    | grep -Eo '([a-zA-Z0-9._-]+\.[a-zA-Z]{2,})' \
    | sort -u > cloud_assets_domains.txt || true
  if [[ -f cloud_assets_domains.txt ]]; then
    grep -E "([a-zA-Z0-9._-]+\.)?${target//./\\.}$" cloud_assets_domains.txt \
      | sed 's/^\*\.//' \
      | anew_or_append all_subs.txt || true
  fi

  local total_cloud total_s3
  total_cloud=$(wc -l < "$cloud_out" 2>/dev/null || echo 0)
  total_s3=$(wc -l < "$s3_out" 2>/dev/null || echo 0)
  echo "[6/6] Cloud findings: $cloud_out (${total_cloud} linhas), $s3_out (${total_s3} linhas)"
}

step_portscan() {
  local hosts_file="${1:-resolved.txt}"
  local ips_file="${2:-resolved_ips.txt}"
  local masscan_out="${3:-masscan_raw.txt}"
  local nmap_out="${4:-nmap_services.xml}"
  local rate="${5:-5000}"
  local wait_time="${6:-0}"
  local port_range="${7:-1-65535}"

  if [[ ! -f "$ips_file" ]]; then
    if [[ ! -f "$hosts_file" ]]; then
      echo "[!] Arquivo de hosts nao encontrado: $hosts_file" >&2
      return 1
    fi
    step_extract_ips "$hosts_file" "$ips_file"
  fi

  local total_ips
  total_ips=$(wc -l < "$ips_file" 2>/dev/null || echo 0)
  if [[ "$total_ips" -eq 0 ]]; then
    echo "[!] Nenhum IP resolvido em: $ips_file" >&2
    return 1
  fi

  if command -v naabu >/dev/null 2>&1; then
    echo "[6/6] Portscan com naabu (orquestrador) + nmap..."
    naabu -list "$ips_file" \
      -p - \
      -exclude-ports 80,443 \
      -c 50 \
      -rate "$rate" \
      -silent \
      -nmap-cli "nmap -sV -sC -oX ${nmap_out}" \
      -o "${masscan_out%.txt}_naabu.txt" 2>/dev/null || true

    naabu -list "$ips_file" \
      -top-ports 1000 \
      -silent \
      -rate "$rate" \
      -o "$masscan_out" 2>/dev/null || true
    return 0
  fi

  require_cmd masscan
  require_cmd nmap

  echo "[6/6] Portscan fase 1 (masscan): ${total_ips} IPs"
  local -a masscan_cmd
  if [[ "${SUBHUNTER_USE_SUDO:-0}" == "1" ]] && command -v sudo >/dev/null 2>&1; then
    masscan_cmd=(sudo masscan)
  else
    masscan_cmd=(masscan)
  fi

  "${masscan_cmd[@]}" -iL "$ips_file" -p"$port_range" --rate "$rate" --wait "$wait_time" -oG "$masscan_out"

  local ports_csv
  ports_csv=$(
    awk '
      /Ports:/ {
        n=split($0, arr, "Ports: ")
        if (n < 2) next
        m=split(arr[2], p, ",")
        for (i=1; i<=m; i++) {
          split(p[i], f, "/")
          if (f[2] == "open" && f[1] ~ /^[0-9]+$/) print f[1]
        }
      }
    ' "$masscan_out" | sort -un | paste -sd, -
  )

  if [[ -z "${ports_csv:-}" ]]; then
    echo "[6/6] Nenhuma porta aberta encontrada pelo masscan; pulando nmap."
    return 0
  fi

  echo "[6/6] Portscan fase 2 (nmap): portas ${ports_csv}"
  nmap -sV -sC -p"$ports_csv" -iL "$ips_file" --open -T4 --min-rate "$rate" --max-retries 1 -oX "$nmap_out"
  echo "[6/6] Nmap finalizado: $nmap_out"
}

step_asn() {
  local input="$1"
  local output="${2:-}"

  if [[ -z "$input" ]]; then
    echo "Uso: recon asn <arquivo_dominios> [arquivo_saida]" >&2
    return 1
  fi
  if [[ ! -f "$input" ]]; then
    echo "[!] Arquivo nao encontrado: $input" >&2
    return 1
  fi

  require_cmd dig
  require_cmd whois

  local tmp
  tmp=$(mktemp)
  sort -u "$input" > "$tmp"

  local header="Domain | IP | ASN | AS Name"
  local sep="-------------------------------------------------------------"

  if [[ -n "$output" ]]; then
    : > "$output"
    echo "$header" | tee -a "$output"
    echo "$sep" | tee -a "$output"
  else
    echo "$header"
    echo "$sep"
  fi

  while IFS= read -r domain; do
    local ip
    ip=$(dig +short "$domain" | grep -Eo '^[0-9.]+$' | head -n1 || true)

    if [[ -z "$ip" ]]; then
      if [[ -n "$output" ]]; then
        echo "$domain | Nao resolveu IP" | tee -a "$output"
      else
        echo "$domain | Nao resolveu IP"
      fi
      continue
    fi

    local result
    result=$(whois -h whois.cymru.com -v "$ip" 2>/dev/null | tail -n +2 || true)

    if [[ -n "$result" ]]; then
      local asn asname
      asn=$(echo "$result" | awk -F'|' '{print $1}' | xargs)
      asname=$(echo "$result" | awk -F'|' '{print $7}' | xargs)
      if [[ -n "$output" ]]; then
        echo "$domain | $ip | AS$asn | $asname" | tee -a "$output"
      else
        echo "$domain | $ip | AS$asn | $asname"
      fi
    else
      if [[ -n "$output" ]]; then
        echo "$domain | $ip | Sem resposta ASN" | tee -a "$output"
      else
        echo "$domain | $ip | Sem resposta ASN"
      fi
    fi
  done < "$tmp"

  rm -f "$tmp"
}

step_cidr_discovery() {
  local target="$1"
  local asn_file="${2:-asninfo.txt}"
  local cidr_hosts_out="${3:-cidr_hosts.txt}"
  local cidr_ptr_out="${4:-cidr_ptr_domains.txt}"

  if ! command -v asnmap >/dev/null 2>&1; then
    echo "[!] asnmap nao encontrado. Pulando CIDR discovery."
    return 0
  fi

  asnmap -d "$target" -silent 2>/dev/null > /tmp/cidr_ranges.txt || true
  if [[ ! -s /tmp/cidr_ranges.txt ]] && [[ -f "$asn_file" ]]; then
    grep -oE 'AS[0-9]+' "$asn_file" 2>/dev/null | grep -oE '[0-9]+' | while read -r asn; do
      asnmap -asn "AS${asn}" -silent 2>/dev/null >> /tmp/cidr_ranges.txt || true
    done
  fi

  : > /tmp/cidr_ips.txt
  if command -v mapcidr >/dev/null 2>&1; then
    cat /tmp/cidr_ranges.txt | mapcidr -silent 2>/dev/null > /tmp/cidr_ips.txt || true
  else
    echo "[!] mapcidr ausente; usando ranges sem expansao de IP." >&2
    cat /tmp/cidr_ranges.txt > /tmp/cidr_ips.txt || true
  fi

  : > "$cidr_hosts_out"
  if [[ -s /tmp/cidr_ips.txt ]]; then
    httpx -l /tmp/cidr_ips.txt \
      -silent \
      -status-code \
      -title \
      -tech-detect \
      -random-agent \
      -o "$cidr_hosts_out" 2>/dev/null || true
  fi

  : > "$cidr_ptr_out"
  if command -v dnsx >/dev/null 2>&1 && [[ -s /tmp/cidr_ips.txt ]]; then
    cat /tmp/cidr_ips.txt | dnsx -silent -ptr -resp-only 2>/dev/null \
      | grep -Eo "([a-zA-Z0-9._-]+\.)+${target//./\\.}" \
      | sed 's/^\*\.//' \
      | sort -u > "$cidr_ptr_out" || true
    cat "$cidr_ptr_out" | anew_or_append all_subs.txt || true
  fi

  rm -f /tmp/cidr_ranges.txt /tmp/cidr_ips.txt

  local http_total ptr_total
  http_total=$(wc -l < "$cidr_hosts_out" 2>/dev/null || echo 0)
  ptr_total=$(wc -l < "$cidr_ptr_out" 2>/dev/null || echo 0)
  echo "[2/6] CIDR discovery finalizado: $cidr_hosts_out (${http_total}), $cidr_ptr_out (${ptr_total})"
}

step_uncover() {
  local target="$1"
  local org_name="${2:-}"
  local output="${3:-uncover_hosts.txt}"

  if [[ -z "$org_name" ]]; then
    org_name=$(echo "$target" | awk -F. '{print $1}')
  fi

  if ! command -v uncover >/dev/null 2>&1; then
    echo "[!] uncover nao encontrado. Pulando uncover."
    return 0
  fi

  : > "$output"
  echo "ssl.cert.subject.cn:\"${target}\"" | uncover -e shodan,censys -silent 2>/dev/null >> "$output" || true
  echo "org:\"${org_name}\"" | uncover -e shodan -silent 2>/dev/null >> "$output" || true
  echo "hostname:\"${target}\"" | uncover -e fofa,hunter -silent 2>/dev/null >> "$output" || true
  sort -u "$output" -o "$output" 2>/dev/null || true

  grep -oE "([a-zA-Z0-9._-]+\.)+${target//./\\.}" "$output" \
    | sed 's/^\*\.//' \
    | anew_or_append all_subs.txt || true

  grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' "$output" \
    | sort -u | anew_or_append resolved_ips.txt 2>/dev/null || true

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[2/6] Uncover finalizado: $output (${total} resultados)"
}

step_amass_intel() {
  local target="$1"
  local asn_file="${2:-asninfo.txt}"
  local output="${3:-amass_intel_domains.txt}"

  if ! command -v amass >/dev/null 2>&1; then
    return 0
  fi

  : > "$output"

  if [[ -f "$asn_file" ]]; then
    grep -oE 'AS[0-9]+' "$asn_file" | grep -oE '[0-9]+' | sort -u > /tmp/asns.txt || true
    local asn
    while IFS= read -r asn; do
      [[ -z "$asn" ]] && continue
      amass intel -asn "$asn" -passive -norecursive 2>/dev/null >> "$output" || true
    done < /tmp/asns.txt
    rm -f /tmp/asns.txt
  fi

  amass intel -whois -d "$target" -passive 2>/dev/null >> "$output" || true

  sort -u "$output" -o "$output" 2>/dev/null || true
  echo "[*] ATENCAO: Revise $output antes de adicionar ao escopo — pode incluir dominios fora do programa"

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[2/6] Amass intel finalizado: $output (${total} dominios)"
}

step_shodan_recon() {
  local target="$1"
  local org_name="${2:-}"
  local asn_file="${3:-asninfo.txt}"
  local output="${4:-shodan_findings.txt}"

  if [[ -z "$target" ]]; then
    echo "Uso: recon shodan <dominio> [--org org_name] [--asn-file asninfo.txt] [--output shodan_findings.txt]" >&2
    return 1
  fi

  if [[ -z "$org_name" ]]; then
    org_name=$(echo "$target" | awk -F. '{print $1}')
  fi

  if [[ -z "${SHODAN_API_KEY:-}" ]]; then
    echo "[!] SHODAN_API_KEY nao definido. Pulando shodan recon."
    return 0
  fi

  : > "$output"

  if command -v shodan >/dev/null 2>&1; then
    shodan search "ssl.cert.subject.cn:${target}" --fields ip_str,port,hostnames,org --limit 200 2>/dev/null >> "$output" || true
    shodan search "org:\"${org_name}\"" --fields ip_str,port,hostnames --limit 200 2>/dev/null >> "$output" || true

    if [[ -f "$asn_file" ]]; then
      awk -F'|' '/AS[0-9]+/ {gsub(/ /,"",$3); print $3}' "$asn_file" 2>/dev/null | sed '/^$/d' | sort -u > .shodan_asn_tmp || true
      while IFS= read -r asn_prefix; do
        [[ -z "$asn_prefix" ]] && continue
        shodan search "net:${asn_prefix}" --fields ip_str,port,hostnames --limit 100 2>/dev/null >> "$output" || true
      done < .shodan_asn_tmp
      rm -f .shodan_asn_tmp
    fi

    grep -oE "([a-zA-Z0-9._-]+\\.)+${target//./\\.}" "$output" | sed 's/^\*\.//' | anew_or_append all_subs.txt || true

    grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' "$output" | sort -u > shodan_ips.txt || true
  else
    curl -s "https://api.shodan.io/shodan/host/search?key=${SHODAN_API_KEY}&query=ssl.cert.subject.cn:${target}&minify=true" \
      | jq -r '.matches[]? | "\(.ip_str):\(.port)"' >> "$output" || true
  fi

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[2/6] Shodan recon finalizado: $output (${total} hosts)"
}

step_subs() {
  local input="$1"
  local mode="${2:-normal}"
  local cookie="${3:-}"

  if [[ -z "$input" ]]; then
    echo "Uso: recon subs <dominio|arquivo.txt> [--mode normal|stealth] [--cookie \"k=v\"]" >&2
    return 1
  fi

  require_cmd curl
  require_cmd jq

  local threads tool_threads
  if [[ "$mode" == "stealth" ]]; then
    threads=3
    tool_threads=25
    echo "[3/5] Modo stealth ativado."
  else
    threads=8
    tool_threads=100
    echo "[3/5] Modo normal ativado."
  fi

  local -a domains=()
  if [[ -f "$input" ]]; then
    mapfile -t domains < <(grep -v '^$' "$input" | sort -u)
  elif [[ "$input" == *.* ]]; then
    domains=("$input")
  else
    echo "[!] Entrada invalida para subdomains: $input" >&2
    return 1
  fi

  local cookie_header=""
  if [[ -n "$cookie" ]]; then
    cookie_header="Cookie: $cookie"
  fi

  local tmp
  tmp=$(mktemp)

  run_passive_domain() {
    local domain="$1"

    if command -v subfinder >/dev/null 2>&1; then
      subfinder -d "$domain" -silent -all -t "$tool_threads" 2>/dev/null >> "$tmp" || true
    fi
    if command -v assetfinder >/dev/null 2>&1; then
      assetfinder --subs-only "$domain" 2>/dev/null >> "$tmp" || true
    fi
    if command -v findomain >/dev/null 2>&1; then
      findomain -t "$domain" -q 2>/dev/null >> "$tmp" || true
    fi
    if command -v amass >/dev/null 2>&1; then
      amass enum -passive -d "$domain" -norecursive -noalts 2>/dev/null >> "$tmp" || true
    fi
    if command -v chaos >/dev/null 2>&1; then
      chaos -d "$domain" -silent 2>/dev/null >> "$tmp" || true
    fi
    if command -v bbot >/dev/null 2>&1; then
      local bbot_dir
      bbot_dir=$(mktemp -d)
      bbot -t "$domain" -f subdomain-enum --silent -o "$bbot_dir" 2>/dev/null || true
      find "$bbot_dir" \( -name "*.txt" -o -name "subdomains.txt" \) 2>/dev/null \
        | xargs cat 2>/dev/null \
        | grep -Eo "([a-zA-Z0-9._-]+\.)+${domain//./\\.}" \
        | sed 's/^\*\.//' >> "$tmp" || true
      rm -rf "$bbot_dir"
    fi

    if [[ -n "$cookie_header" ]]; then
      curl -s -H "$cookie_header" "https://crt.sh/?q=%25.$domain&output=json" 2>/dev/null | \
        jq -r '.[].name_value?' 2>/dev/null | \
        sed 's/\*\.//g' | grep -i "\.$domain$" >> "$tmp" || true
    else
      curl -s "https://crt.sh/?q=%25.$domain&output=json" 2>/dev/null | \
        jq -r '.[].name_value?' 2>/dev/null | \
        sed 's/\*\.//g' | grep -i "\.$domain$" >> "$tmp" || true
    fi

    curl -s "https://dns.bufferover.run/dns?q=.$domain" 2>/dev/null | \
      jq -r '.FDNS_A[]?' 2>/dev/null | \
      cut -d',' -f2 >> "$tmp" || true

    curl -s "https://urlscan.io/api/v1/search/?q=domain:$domain" 2>/dev/null | \
      jq -r '.results[].page.domain?' 2>/dev/null >> "$tmp" || true

    ############################################################
    # BLOCO 1 — Fontes Passivas Adicionais (GitHub + Wayback)
    ############################################################

    # Wayback CDX: extrai hosts historicos arquivados.
    curl -s "https://web.archive.org/cdx/search/cdx?url=*.${domain}/*&output=text&fl=original&collapse=urlkey" 2>/dev/null | \
      sed 's#^[a-zA-Z][a-zA-Z0-9+.-]*://##' | \
      cut -d'/' -f1 | \
      sed 's/:.*$//' | \
      sed 's/^\*\.//' | \
      grep -iE "([a-zA-Z0-9._-]+\.)+${domain//./\\.}$" >> "$tmp" || true

    # GitHub: busca referencias de subdominios em codigo/indexacao.
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
      local page
      for page in 1 2; do
        curl -s -H "Authorization: Bearer ${GITHUB_TOKEN}" \
          -H "Accept: application/vnd.github.text-match+json" \
          "https://api.github.com/search/code?q=%22.${domain}%22&per_page=100&page=${page}" 2>/dev/null | \
          jq -r '.items[]?.text_matches[]?.fragment?' 2>/dev/null | \
          grep -Eo "([a-zA-Z0-9._-]+\\.)+${domain//./\\.}" >> "$tmp" || true
      done
    else
      # Fallback sem token: scraping simples da busca publica.
      curl -sL "https://github.com/search?q=%22.${domain}%22&type=code" 2>/dev/null | \
        grep -Eo "([a-zA-Z0-9._-]+\\.)+${domain//./\\.}" >> "$tmp" || true
    fi
  }

  local -a pids=()
  for domain in "${domains[@]}"; do
    while [[ $(jobs -p | wc -l) -ge $threads ]]; do
      sleep 1
    done
    run_passive_domain "$domain" &
    pids+=("$!")
  done

  local pid
  for pid in "${pids[@]}"; do
    wait "$pid" || true
  done

  if [[ -f "all_subs.txt" ]]; then
    cat all_subs.txt >> "$tmp" || true
  fi

  tr '[:upper:]' '[:lower:]' < "$tmp" \
    | grep -E '^[a-zA-Z0-9._-]+\.[a-zA-Z]{2,}$' \
    | sort -u > all_subs.txt || true

  rm -f "$tmp"

  local total
  total=$(wc -l < all_subs.txt 2>/dev/null || echo 0)
  echo "[3/5] Wordlist criada: all_subs.txt (${total} subs)"
}

step_smartenum() {
  local input="${1:-base_patterns.txt}"
  local output="${2:-smart_wordlist.txt}"

  if [[ "$input" == "base_patterns.txt" ]] && [[ -f "resolved.txt" ]] && command -v unfurl >/dev/null 2>&1; then
    echo "[4/5] Gerando base_patterns.txt a partir de resolved.txt..."
    cat resolved.txt | unfurl -u domains | sed 's/\..*//' | sort -u > base_patterns.txt
  elif [[ "$input" == "base_patterns.txt" ]] && [[ -f "all_subs.txt" ]]; then
    echo "[4/5] Gerando base_patterns.txt a partir de all_subs.txt (fallback)..."
    sed 's/\..*//' all_subs.txt | sort -u > base_patterns.txt
  fi

  if [[ ! -f "$input" ]]; then
    echo "[!] Arquivo nao encontrado: $input" >&2
    return 1
  fi

  echo "[4/5] Extraindo prefixos base..."
  sort -u "$input" > tmp_unique.txt

  echo "[4/5] Detectando ambientes..."
  grep -E '^(dev|hml|prd|prod|homolog|qa|uat)$' tmp_unique.txt > tmp_envs.txt || true

  if [[ ! -s tmp_envs.txt ]]; then
    printf "dev\nhml\nprd\nqa\nuat\n" > tmp_envs.txt
  fi

  echo "[4/5] Detectando padroes numericos finais..."
  grep -E '[0-9]+$' tmp_unique.txt > tmp_numeric.txt || true
  sed 's/[0-9]*$//' tmp_numeric.txt | sort -u > tmp_numeric_base.txt

  : > "$output"

  while IFS= read -r base; do
    [[ -z "$base" ]] && continue
    local i
    for i in $(seq -w 001 050); do
      echo "${base}${i}" >> "$output"
    done
  done < tmp_numeric_base.txt

  grep -E '^[a-zA-Z]+[0-9]+-[0-9]+$' tmp_unique.txt > tmp_pm.txt || true

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local prefix
    prefix=$(echo "$line" | sed -E 's/-[0-9]+$//')
    local i
    for i in $(seq 1 20); do
      echo "${prefix}-${i}" >> "$output"
    done
  done < tmp_pm.txt

  echo "[4/5] Detectando servicos principais..."
  awk -F'-' '{print $1}' tmp_unique.txt | sort | uniq -c | sort -nr | awk '$1 > 2 {print $2}' > tmp_services.txt

  local service env
  while IFS= read -r service; do
    [[ -z "$service" ]] && continue
    while IFS= read -r env; do
      [[ -z "$env" ]] && continue
      echo "${service}-${env}" >> "$output"
      echo "${env}-${service}" >> "$output"
    done < tmp_envs.txt
  done < tmp_services.txt

  if grep -qE '^vpn-[a-z]$' tmp_unique.txt; then
    local c
    for c in {a..z}; do
      echo "vpn-$c" >> "$output"
    done
  fi

  if grep -qE '^www[0-9]*$' tmp_unique.txt; then
    local n
    for n in $(seq 1 10); do
      echo "www$n" >> "$output"
    done
  fi

  sort -u "$output" -o "$output"
  rm -f tmp_unique.txt tmp_envs.txt tmp_numeric.txt tmp_numeric_base.txt tmp_pm.txt tmp_services.txt

  echo "[4/5] Wordlist inteligente gerada em: $output"
  wc -l "$output"
}

step_bruteforce() {
  local target="$1"
  local wordlist="${2:-smart_wordlist.txt}"
  local resolvers="${3:-resolvers.txt}"
  local rate_limit="${4:-1000}"
  local wildcard_tests="${5:-50}"
  local wildcard_batch="${6:-1000000}"
  local output="${7:-brute_raw.txt}"

  if [[ -z "$target" ]]; then
    echo "Uso: recon bruteforce <dominio> [--wordlist smart_wordlist.txt] [--resolvers resolvers.txt] [--rate-limit 1000] [--wildcard-tests 50] [--wildcard-batch 1000000] [--output brute_raw.txt]" >&2
    return 1
  fi

  require_cmd puredns

  if [[ ! -f "$wordlist" ]]; then
    echo "[!] Wordlist nao encontrada: $wordlist" >&2
    return 1
  fi

  if [[ ! -f "$resolvers" ]]; then
    echo "[!] Arquivo de resolvers nao encontrado: $resolvers" >&2
    return 1
  fi

  echo "[5/6] Iniciando puredns bruteforce..."
  puredns bruteforce "$wordlist" "$target" \
    -r "$resolvers" \
    --rate-limit "$rate_limit" \
    --wildcard-tests "$wildcard_tests" \
    --wildcard-batch "$wildcard_batch" \
    -w "$output" || true

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[5/6] Bruteforce finalizado: $output (${total} entradas)"
}

step_merge_validate() {
  local passive_file="${1:-all_subs.txt}"
  local brute_file="${2:-brute_raw.txt}"
  local merged_file="${3:-all_subs_merged.txt}"
  local resolvers="${4:-resolvers.txt}"
  local output="${5:-resolved.txt}"
  local force_resolve="${6:-0}"

  require_cmd sort

  if [[ ! -f "$passive_file" ]] && [[ ! -f "$brute_file" ]]; then
    echo "[!] Nenhuma fonte encontrada para validar hosts (passive/brute)." >&2
    return 1
  fi

  : > "$merged_file"
  if [[ -f "$passive_file" ]]; then
    cat "$passive_file" >> "$merged_file"
  fi
  if [[ -f "$brute_file" ]]; then
    cat "$brute_file" >> "$merged_file"
  fi

  tr '[:upper:]' '[:lower:]' < "$merged_file" \
    | grep -E '^[a-zA-Z0-9._-]+\.[a-zA-Z]{2,}$' \
    | sort -u > "${merged_file}.tmp" || true
  mv "${merged_file}.tmp" "$merged_file"

  local total_merged
  total_merged=$(wc -l < "$merged_file" 2>/dev/null || echo 0)
  echo "[6/6] Lista unificada criada: $merged_file (${total_merged} hosts)"

  if [[ -f "$resolvers" ]] && command -v puredns >/dev/null 2>&1; then
    if [[ -s "$output" && "$force_resolve" != "1" ]]; then
      echo "[+] $output ja existe, pulando resolucao (use --force-resolve para refazer)"
      return 0
    fi
    echo "[6/6] Validando hosts ativos com puredns resolve..."
    puredns resolve "$merged_file" -r "$resolvers" -w "$output" >/dev/null 2>&1 || true
    local total_resolved
    if [[ -f "$output" ]]; then
      total_resolved=$(wc -l < "$output" 2>/dev/null || echo 0)
    else
      total_resolved=0
    fi
    echo "[6/6] Validacao finalizada: $output (${total_resolved} ativos)"
  else
    echo "[6/6] resolvers.txt ou puredns ausente. Pulando validacao de hosts."
  fi
}

step_build_subdomains() {
  local target="$1"
  local output="${2:-subdomains.txt}"

  if [[ -z "$target" ]]; then
    echo "Uso: recon buildsubs <dominio> [--output subdomains.txt]" >&2
    return 1
  fi

  local tmp_hosts tmp_labels
  tmp_hosts=$(mktemp)
  tmp_labels=$(mktemp)

  # Fontes que ja vieram das etapas anteriores.
  for src in resolved.txt all_subs_merged.txt all_subs.txt brute_raw.txt; do
    if [[ -f "$src" ]]; then
      cat "$src" >> "$tmp_hosts"
    fi
  done

  # Extraindo labels dos subdominios ja descobertos para o alvo.
  if [[ -s "$tmp_hosts" ]]; then
    awk -v target="$target" '
      {
        d=tolower($0)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", d)
        gsub(/^\*\./, "", d)
        gsub(/\.$/, "", d)
        if (d == "" || d == target) next

        suffix="." target
        if (length(d) > length(suffix) && substr(d, length(d)-length(suffix)+1) == suffix) {
          sub("\\." target "$", "", d)
          n=split(d, p, ".")
          if (n >= 1 && p[1] ~ /^[a-z0-9][a-z0-9-]*$/) print p[1]
        }
      }
    ' "$tmp_hosts" >> "$tmp_labels"
  fi

  # Aproveita seeds das listas ja geradas no pipeline.
  for src in smart_wordlist.txt base_patterns.txt; do
    if [[ -f "$src" ]]; then
      cat "$src" >> "$tmp_labels"
    fi
  done

  tr '[:upper:]' '[:lower:]' < "$tmp_labels" \
    | sed 's/^\*\.\?//' \
    | sed 's/\..*//' \
    | grep -E '^[a-z0-9][a-z0-9-]{0,62}$' \
    | sort -u > "${output}.seed" || true

  : > "$output"
  cat "${output}.seed" >> "$output"

  # Expansao inteligente com base no que foi observado.
  grep -E '[0-9]+$' "${output}.seed" | sed 's/[0-9]*$//' | sort -u > "${output}.numeric_base" || true
  while IFS= read -r base; do
    [[ -z "$base" ]] && continue
    for i in $(seq -w 001 050); do
      echo "${base}${i}" >> "$output"
    done
  done < "${output}.numeric_base"

  grep -E '^(dev|hml|prd|prod|homolog|qa|uat|stg|stage|test)$' "${output}.seed" > "${output}.envs" || true
  if [[ ! -s "${output}.envs" ]]; then
    printf "dev\nhml\nprd\nqa\nuat\nstg\ntest\n" > "${output}.envs"
  fi

  awk -F'[-_]' '{print $1}' "${output}.seed" | sort | uniq -c | sort -nr | awk '$1 > 1 {print $2}' > "${output}.services"
  while IFS= read -r service; do
    [[ -z "$service" ]] && continue
    while IFS= read -r env; do
      [[ -z "$env" ]] && continue
      echo "${service}-${env}" >> "$output"
      echo "${env}-${service}" >> "$output"
    done < "${output}.envs"
  done < "${output}.services"

  sort -u "$output" -o "$output"
  rm -f "$tmp_hosts" "$tmp_labels" "${output}.seed" "${output}.numeric_base" "${output}.envs" "${output}.services"

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[6/6] Wordlist inteligente de subdominios gerada: $output (${total} entradas)"
}

step_build_paths() {
