database
upload
uploads
download
downloads
files
tmp
dev
test
staging
homolog
qa
prod
EOF

  # Termos inferidos dos artefatos gerados anteriormente.
  for src in base_patterns.txt smart_wordlist.txt subdomains.txt all_subs.txt all_subs_merged.txt resolved.txt brute_raw.txt; do
    if [[ -f "$src" ]]; then
      cat "$src" >> "$tmp_terms"
    fi
  done

  if [[ -f "results/path_fuzz.json" ]] && command -v jq >/dev/null 2>&1; then
    jq -r '.results[]?.input?.FUZZ?' results/path_fuzz.json 2>/dev/null >> "$tmp_terms" || true
  fi

  tr '[:upper:]' '[:lower:]' < "$tmp_terms" \
    | sed 's/^\*\.\?//' \
    | sed 's#https\?://##g' \
    | sed 's#/.*##' \
    | sed 's/\..*//' \
    | tr '._' '-' \
    | sed 's/[^a-z0-9-]//g' \
    | grep -E '^[a-z0-9][a-z0-9-]{1,30}$' \
    | sort -u > "${output}.terms" || true

  if [[ -s "${output}.terms" ]]; then
    cat "${output}.terms" >> "$tmp_paths"

    # Expande em namespaces e versões comuns.
    while IFS= read -r t; do
      [[ -z "$t" ]] && continue
      echo "$t/api" >> "$tmp_paths"
      echo "$t/admin" >> "$tmp_paths"
      echo "$t/login" >> "$tmp_paths"
      echo "$t/v1" >> "$tmp_paths"
      echo "$t/v2" >> "$tmp_paths"
      echo "api/$t" >> "$tmp_paths"
      echo "internal/$t" >> "$tmp_paths"
      echo "v1/$t" >> "$tmp_paths"
      echo "v2/$t" >> "$tmp_paths"
    done < "${output}.terms"
  fi

  tr '[:upper:]' '[:lower:]' < "$tmp_paths" \
    | tr -d '\r' \
    | sed 's#^/*##' \
    | sed 's#[^a-z0-9._/-]##g' \
    | sed 's#//*#/#g' \
    | sed 's#^/##' \
    | sed 's#/$##' \
    | grep -v '^$' \
    | sort -u > "$output"

  rm -f "$tmp_terms" "$tmp_paths" "${output}.terms"

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[6/6] Wordlist inteligente de paths gerada: $output (${total} entradas)"
}

step_live_hosts() {
