  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[6/6] Hosts vivos salvos em: $output (${total} entradas)"
}

step_httpx_full() {
  local input="${1:-resolved.txt}"
  local output="${2:-httpx_full.txt}"
  local live_file="${3:-live.txt}"
  local ips_file="${4:-resolved_ips.txt}"
  local waf_out="${5:-waf_results.txt}"
  local cdn_out="${6:-cdn_results.txt}"
  local ssl_out="${7:-ssl_results.json}"
  local favicon_out="${output%.txt}_favicons.txt"

  if [[ ! -f "$input" ]]; then
    echo "[!] Arquivo nao encontrado: $input" >&2
    return 1
  fi

  require_cmd httpx

  echo "[6/6] Coletando fingerprint HTTP completo com httpx..."
  httpx -list "$input" \
    -status-code \
    -content-length \
    -content-type \
    -line-count \
    -title \
    -body-preview \
    -server \
    -tech-detect \
    -probe-all-ips \
    -include-response \
    -follow-host-redirects \
    -random-agent \
    -o "$output" || true

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[6/6] Saida completa do httpx salva em: $output (${total} linhas)"

  # Extração de favicon hash + correlação com Shodan
  if command -v httpx >/dev/null 2>&1 && [[ -f "$live_file" ]]; then
    httpx -list "$live_file" -favicon -hash sha256 -silent -o "$favicon_out" 2>/dev/null || true
    grep -oE 'sha256:[a-f0-9]+' "$favicon_out" | sort -u > "${favicon_out%.txt}_hashes.txt" || true

    if command -v shodan >/dev/null 2>&1; then
      : > "${favicon_out%.txt}_shodan.txt"
      while IFS= read -r hash; do
        [[ -z "$hash" ]] && continue
        shodan search "http.favicon.hash:$hash" --fields ip_str,port,hostnames 2>/dev/null >> "${favicon_out%.txt}_shodan.txt" || true
      done < "${favicon_out%.txt}_hashes.txt"

      local shodan_total
      shodan_total=$(wc -l < "${favicon_out%.txt}_shodan.txt" 2>/dev/null || echo 0)
      echo "[6/6] Favicon/Shodan finalizado: ${favicon_out%.txt}_shodan.txt (${shodan_total} resultados)"
    else
      echo "[6/6] shodan CLI ausente. Use manualmente: https://www.shodan.io/search?query=http.favicon.hash:<HASH>"
    fi
  fi

  # Etapa 15: WAF/CDN detection
  : > "$waf_out"
  : > "$cdn_out"

  if command -v wafw00f >/dev/null 2>&1 && [[ -f "$live_file" ]]; then
    echo "[6/6] Detectando WAF com wafw00f..."
    wafw00f -i "$live_file" -o "$waf_out" -f json >/dev/null 2>&1 || true
  else
    echo "[!] wafw00f ausente ou arquivo live nao encontrado: $live_file" >> "$waf_out"
  fi

  if command -v cdncheck >/dev/null 2>&1 && [[ -f "$ips_file" ]]; then
    echo "[6/6] Detectando CDN com cdncheck..."
    cdncheck -l "$ips_file" -o "$cdn_out" >/dev/null 2>&1 || true
  else
    echo "[!] cdncheck ausente ou arquivo de IPs nao encontrado: $ips_file" >> "$cdn_out"
  fi

  : > "$ssl_out"
  if command -v testssl.sh >/dev/null 2>&1 && [[ -f "$live_file" ]]; then
    echo "[6/6] Testando SSL/TLS com testssl.sh..."
    testssl.sh --file "$live_file" --jsonfile "$ssl_out" --quiet >/dev/null 2>&1 || true
  else
    echo "[!] testssl.sh ausente ou arquivo live nao encontrado: $live_file" > "$ssl_out"
  fi

  local waf_total cdn_total ssl_total
  waf_total=$(wc -l < "$waf_out" 2>/dev/null || echo 0)
  cdn_total=$(wc -l < "$cdn_out" 2>/dev/null || echo 0)
  ssl_total=$(wc -l < "$ssl_out" 2>/dev/null || echo 0)
  echo "[6/6] WAF/CDN/SSL finalizado: $waf_out (${waf_total}), $cdn_out (${cdn_total}), $ssl_out (${ssl_total})"
}

