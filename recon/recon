step_fuzz() {
  local target="$1"
  local wordlist_subs="${2:-subdomains.txt}"
  local wordlist_paths="${3:-paths.txt}"
  local threads="${4:-80}"
  local results_dir="${5:-results}"

  if [[ -z "$target" ]]; then
    echo "Uso: recon fuzz <dominio> [--subs subdomains.txt] [--paths paths.txt] [--threads 80] [--results results]" >&2
    return 1
  fi

  require_cmd curl
  require_cmd ffuf
  require_cmd openssl

  if [[ ! -f "$wordlist_subs" ]]; then
    echo "[!] Wordlist de subdominios nao encontrada: $wordlist_subs" >&2
    return 1
  fi

  if [[ ! -f "$wordlist_paths" ]]; then
    echo "[!] Wordlist de paths nao encontrada: $wordlist_paths" >&2
    return 1
  fi

  mkdir -p "$results_dir"

  echo "[5/5] Detectando tamanho base HTTP..."
  local base_size random_size filter
  base_size=$(curl -s -o /dev/null -w "%{size_download}" "http://${target}" || echo 0)
  random_size=$(curl -s -o /dev/null -w "%{size_download}" -H "Host: $(openssl rand -hex 6).${target}" "http://${target}" || echo 0)

  echo "[5/5] Tamanho base: $base_size"
  echo "[5/5] Tamanho wildcard: $random_size"

  if [[ "$base_size" == "$random_size" ]]; then
    echo "[5/5] Wildcard detectado, aplicando filtro por tamanho"
    filter=("-fs" "$base_size")
  else
    echo "[5/5] Sem wildcard detectado"
    filter=()
  fi

  echo "[5/5] Iniciando VHost discovery..."
  ffuf -w "$wordlist_subs" \
    -u "http://${target}" \
    -H "Host: FUZZ.${target}" \
    "${filter[@]}" \
    -mc 200,301,302,403 \
    -t "$threads" \
    -o "${results_dir}/vhosts.json" -of json

  echo "[5/5] Iniciando API subdomain fuzz..."
  ffuf -w "$wordlist_subs" \
    -u "https://FUZZ.api.${target}" \
    -mc 200,301,302,403 \
    -t "$threads" \
    -o "${results_dir}/api_prefix.json" -of json

  ffuf -w "$wordlist_subs" \
    -u "https://api.FUZZ.${target}" \
    -mc 200,301,302,403 \
    -t "$threads" \
    -o "${results_dir}/api_namespace.json" -of json

  echo "[5/5] Iniciando Path fuzzing..."
  ffuf -w "$wordlist_paths" \
    -u "https://${target}/FUZZ" \
    -mc 200,301,302,403 \
    -t "$threads" \
    -o "${results_dir}/path_fuzz.json" -of json

  echo "[5/5] Fuzzing finalizado."
  echo "[5/5] Resultados em ./${results_dir}/"
}

step_kiterunner() {
  local live_file="${1:-live.txt}"
  local routes_file="${2:-routes-large.kite}"
  local output="${3:-kiterunner_results.txt}"
  local threads="${4:-10}"

  if ! command -v kr >/dev/null 2>&1; then
    return 0
  fi
  if [[ ! -f "$live_file" ]]; then
    echo "[!] Arquivo nao encontrado: $live_file" >&2
    return 1
  fi
  if [[ ! -f "$routes_file" ]]; then
    echo "[*] routes-large.kite nao encontrado. Baixe em: https://github.com/assetnote/kiterunner"
    echo "[*] Tentando com routes-small.kite..."
    routes_file="routes-small.kite"
    if [[ ! -f "$routes_file" ]]; then
      echo "[!] Nenhum arquivo .kite encontrado. Pulando kiterunner." >&2
      return 0
    fi
  fi

  awk '{print $1}' "$live_file" \
    | grep -E '^https?://' \
    | sed -E 's#(https?://[^/]+).*#\1#' \
    | sort -u > /tmp/kr_targets.txt

  kr scan /tmp/kr_targets.txt \
    -w "$routes_file" \
    -j "$threads" \
    --ignore-length=34 \
    -o "$output" 2>/dev/null || true

  rm -f /tmp/kr_targets.txt

  local total
  total=$(wc -l < "$output" 2>/dev/null || echo 0)
  echo "[6/6] Kiterunner finalizado: $output (${total} endpoints)"
}

