    target="${1:-}"
    shift || true
    subs="subdomains.txt"
    paths="paths.txt"
    threads=80
    results_dir="results"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --subs)
          subs="${2:-$subs}"
          shift 2
          ;;
        --paths)
          paths="${2:-$paths}"
          shift 2
          ;;
        --threads)
          threads="${2:-$threads}"
          shift 2
          ;;
        --results)
          results_dir="${2:-$results_dir}"
          shift 2
          ;;
        *)
          echo "[!] Opcao invalida: $1" >&2
          exit 1
          ;;
      esac
    done
    step_fuzz "$target" "$subs" "$paths" "$threads" "$results_dir"
    ;;
  kiterunner)
    live_file="live.txt"
    routes_file="routes-large.kite"
    output="kiterunner_results.txt"
    threads="10"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --live)
          live_file="${2:-$live_file}"
          shift 2
          ;;
        --routes)
          routes_file="${2:-$routes_file}"
          shift 2
          ;;
        --output)
          output="${2:-$output}"
          shift 2
          ;;
        --threads)
          threads="${2:-$threads}"
          shift 2
          ;;
        *)
          echo "[!] Opcao invalida: $1" >&2
          exit 1
          ;;
      esac
    done
    step_kiterunner "$live_file" "$routes_file" "$output" "$threads"
    ;;
  all)
    target_input="${1:-}"
    shift || true
    mode="normal"
    cookie=""
    patterns="base_patterns.txt"
    subs="subdomains.txt"
    paths="paths.txt"
    threads=80
    force_resolve="0"

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --mode)
          mode="${2:-$mode}"
          shift 2
          ;;
        --cookie)
          cookie="${2:-}"
          shift 2
          ;;
        --patterns)
          patterns="${2:-$patterns}"
          shift 2
          ;;
        --subs)
          subs="${2:-$subs}"
          shift 2
          ;;
        --paths)
          paths="${2:-$paths}"
          shift 2
          ;;
        --threads)
          threads="${2:-$threads}"
          shift 2
          ;;
        --force-resolve)
          force_resolve="1"
          shift 1
          ;;
        *)
          echo "[!] Opcao invalida: $1" >&2
          exit 1
          ;;
      esac
    done

    if [[ -z "$target_input" ]]; then
      echo "Uso: recon all <dominio|arquivo.txt> [...]" >&2
      exit 1
    fi

    if [[ -f "$target_input" ]]; then
      mapfile -t targets < <(grep -v '^$' "$target_input" | sort -u)
    else
      targets=("$target_input")
    fi

    if [[ "${#targets[@]}" -eq 0 ]]; then
      echo "[!] Nenhum dominio valido encontrado." >&2
      exit 1
    fi

    for target in "${targets[@]}"; do
      if [[ "$target" != *.* ]]; then
        echo "[!] Dominio invalido, pulando: $target"
        continue
      fi
      run_all_pipeline_for_target "$target" "$mode" "$cookie" "$patterns" "$subs" "$paths" "$threads" "$force_resolve"
    done
    ;;

  -h|--help|help|"")
    usage
    ;;

  *)
    echo "[!] Comando invalido: $cmd" >&2
    usage
    exit 1
    ;;
esac
